REFLEXION_RUNTIME=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: use another OpenAI-compatible endpoint.
# REFLEXION_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: used only for cost display in report.json/report.md.
# Defaults below are low-cost GPT-4o-mini style estimates per 1K tokens.
REFLEXION_INPUT_PRICE_PER_1K_TOKENS=0.00015
REFLEXION_OUTPUT_PRICE_PER_1K_TOKENS=0.0006
REFLEXION_USD_TO_VND=25000
